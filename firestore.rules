
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read and write only their own data
    // This will cover /users/{userId}/words/{wordId} as well
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Word Details Cache
    // Document ID is the lowercased word
    match /wordDetailsCache/{wordText} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Allows authenticated users to write via server-side logic.
    }
    
    // Deny all other access to paths not explicitly matched by rules above.
    // This must come AFTER specific rules for /users and /wordDetailsCache.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
